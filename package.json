{
  "name": "pressa",
  "version": "0.1.0",
  "description": "CLI for Pressa — Compile-as-a-Service. LaTeX in, PDF out.",
  "bin": {
    "pressa": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "postinstall": "node install-skill.js",
    "prepublishOnly": "tsc"
  },
  "files": [
    "dist",
    "SKILL.md",
    "install-skill.js"
  ],
  "keywords": [
    "latex",
    "pdf",
    "compile",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nikolatodorovic/pressa-cli.git"
  },
  "author": "Pressa <hello@pressa.dev>",
  "homepage": "https://pressa.dev",
  "bugs": {
    "url": "https://github.com/nikolatodorovic/pressa-cli/issues"
  },
  "type": "module",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
